# euphoricfm-website — Caddy serving the static Astro build PUBLICLY.
#
# As of 0.4.0 this container is the public ingress for info.euphoric.fm —
# Cloudflare proxy was removed because a custom in-game phone CEF iframe
# couldn't load Cloudflare-fronted content. Caddy now terminates TLS
# directly via Let's Encrypt and binds 0.0.0.0:443 / 0.0.0.0:80.
#
# The site lives inside an in-game phone's iframe, so we explicitly allow
# embedding from anywhere via CSP frame-ancestors and DO NOT set X-Frame-Options.
#
# Container hardening (see docker-compose.yml):
#   - no-new-privileges  → can't setuid-escalate
#   - cap_drop ALL       → root inside the container has zero capabilities
#   - cap_add NET_BIND_SERVICE → just enough to bind 80/443
#   - read-only root fs  → /etc, /usr, /srv all immutable at runtime
#   - tmpfs /tmp         → no persistence for scratch
#   - named volumes /data + /config → Let's Encrypt cert persistence only

{
  # Disable the admin API. Even bound to localhost inside the container it's
  # an extra attack surface we don't need — we never reconfigure at runtime.
  admin off

  # Email for Let's Encrypt expiry notices. Optional but recommended.
  email jasonholmes1120@gmail.com

  # HTTP/1.1 + HTTP/2 only. NO HTTP/3 — the custom in-game phone CEF was
  # hanging on QUIC negotiation. Without this, Caddy advertises HTTP/3 via
  # `alt-svc` and capable-but-broken clients try it and never fall back.
  servers {
    protocols h1 h2
  }

  # Caddy emits informational logs to stdout by default; keep that.
}

# ---------------------------------------------------------------------------
# Apex site — info.euphoric.fm — public HTTPS via Let's Encrypt
# ---------------------------------------------------------------------------
{$SITE_HOSTNAME:info.euphoric.fm} {
  root * /srv/site
  encode gzip zstd

  # Force RSA cert (chains to LE R3/R10/R11 → ISRG Root X1, universally
  # trusted since ~2017). Default ECDSA chain goes via ISRG Root X2 which
  # newer-but-not-universal — some custom in-game phone CEF builds don't
  # have it in their CA bundle and silently fail TLS validation.
  tls {
    key_type rsa2048
  }

  # ---- Security headers --------------------------------------------------
  header {
    # HSTS — once a browser sees this, it forces HTTPS for the next year.
    # NOT including preload because we're not on the HSTS preload list and
    # adding subdomains here could break other host names on euphoric.fm.
    Strict-Transport-Security "max-age=31536000"

    # MIME sniffing protection.
    X-Content-Type-Options "nosniff"

    # Don't leak the full URL on outbound links to other origins.
    Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy — explicitly opt OUT of features we never use.
    # Geolocation, camera, mic, payment APIs, etc. are all denied. This
    # narrows blast radius of any future supply-chain / XSS bug.
    Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"

    # Allow embedding from anywhere — required for the in-game phone iframe.
    Content-Security-Policy "frame-ancestors *"

    # Remove default X-Frame-Options so it doesn't conflict with frame-ancestors.
    -X-Frame-Options

    # Don't leak our reverse-proxy software in responses.
    -Server
  }

  # ---- Runtime-injected config ------------------------------------------
  # Caddy renders /efm-runtime-config.js inline from env vars at request time
  # so webhook URLs aren't baked into the static bundle. Edit `.env` +
  # `docker compose up -d` to swap a webhook; no rebuild needed.
  #
  # SECURITY NOTE: these webhook URLs ARE exposed to anyone visiting the
  # site — that's a deliberate trade-off (client posts directly to Discord
  # so Discord sees real user IPs for its own rate limiting). If the
  # webhooks ever get abused at scale, rotate them in the Discord channel
  # settings and update .env.
  @runtimeConfig path /efm-runtime-config.js
  handle @runtimeConfig {
    header Content-Type "application/javascript; charset=utf-8"
    header Cache-Control "no-store"
    respond `(function(){window.__EFM_CONFIG__=window.__EFM_CONFIG__||{};window.__EFM_CONFIG__.discord={requestWebhook:"{$PUBLIC_DISCORD_REQUEST_WEBHOOK}",contactWebhook:"{$PUBLIC_DISCORD_CONTACT_WEBHOOK}"};})();`
  }

  # ---- Shared pending-requests API --------------------------------------
  # Tiny Node service in the `efm-requests` container holds the cross-visitor
  # pending-requests list (v0.6.0 was per-browser localStorage, this is the
  # shared version). Reachable on the default compose network. See
  # server/index.mjs for the endpoint shape.
  handle /requests/* {
    reverse_proxy efm-requests:3000
  }

  # ---- Album-art same-origin proxy --------------------------------------
  # Album art comes from euphoric.fm (cross-origin to info.euphoric.fm). To
  # extract the dominant colour from the current track's art we read it onto a
  # <canvas>, but a cross-origin image taints the canvas and blocks
  # getImageData(). Routing art through our own origin makes the canvas read
  # clean. `handle_path` strips the /efm-art prefix, so /efm-art/api/station/1/
  # art/<hash> proxies to https://euphoric.fm/api/station/1/art/<hash>.
  # Streaming proxy — nothing is written to the read-only container FS; the
  # Cache-Control header is just a browser hint. ACAO is belt-and-suspenders
  # (the read is same-origin already).
  handle_path /efm-art/* {
    reverse_proxy https://euphoric.fm {
      header_up Host euphoric.fm
    }
    header Access-Control-Allow-Origin "*"
    header Cache-Control "public, max-age=300"
  }

  # ---- AzuraCast request-submit proxy -----------------------------------
  # AzuraCast's `POST /api/station/<id>/request/<songId>` returns its reply
  # WITHOUT an `Access-Control-Allow-Origin` header (the OPTIONS preflight
  # has one, the actual POST does not — and the 500 "already requested"
  # error responses also don't). Cross-origin POSTs from this site land
  # server-side but the browser blocks JS from reading the reply, so
  # `fetch()` rejects and the modal shows "Network error submitting
  # request." even when the song actually got queued.
  #
  # Fix: reverse-proxy `/api/*` to euphoric.fm so the request modal POSTs
  # same-origin. The frequent now-playing/library GETs DO return ACAO and
  # keep going to euphoric.fm directly (apiBase in site.config.ts), so this
  # only sees the rare request-submit traffic.
  handle /api/* {
    reverse_proxy https://euphoric.fm {
      header_up Host euphoric.fm
    }
  }

  # ---- Static file serving ----------------------------------------------
  file_server

  # Fingerprinted Astro assets — cache forever.
  @astroAssets path /_astro/*
  header @astroAssets Cache-Control "public, max-age=31536000, immutable"

  # Font files don't change once shipped — cache hard.
  @fonts path /fonts/*
  header @fonts Cache-Control "public, max-age=31536000, immutable"

  # Images cached for a week.
  @images path /images/*
  header @images Cache-Control "public, max-age=604800"

  # Icons and small meta files cached a day.
  @icons path /favicon.svg /favicon.ico /robots.txt /sitemap-index.xml /sitemap-*.xml
  header @icons Cache-Control "public, max-age=86400"

  # Service worker MUST not be cached aggressively or old killswitch behaviour sticks.
  @sw path /sw.js
  header @sw Cache-Control "no-cache, no-store, must-revalidate"

  handle_errors {
    @404 expression `{err.status_code} == 404`
    handle @404 {
      header Cache-Control "no-store, max-age=0"
      respond "Page not found — try the home page at /" 404
    }
  }

  # Access log — useful for spotting abuse patterns. JSON to stdout, capped
  # at the docker logging driver level (see docker-compose.yml).
  log {
    output stdout
    format json
    # Don't log the runtime-config endpoint — its response body includes
    # webhook URLs and we don't want them in logs.
    level INFO
  }
}

# ---------------------------------------------------------------------------
# tickets.euphoric.gg — direct DNS A record → VPS IP → this Caddy →
# tickets-web:3000 on efm-public-net.
#
# `tickets.euphoric.fm` is intentionally NOT served here — it goes through
# the existing cloudflared tunnel which terminates TLS at Cloudflare's edge
# and forwards to 127.0.0.1:6095 directly. No Caddy block needed (and
# adding one would just spam logs with failing ACME challenges since
# .fm DNS doesn't resolve to this VPS).
#
# Out-of-band setup required for `.gg`:
#   1. DNS A record `tickets.euphoric.gg → <VPS IP>`, Cloudflare proxy OFF.
#      (CEF iframe constraint, same as info.euphoric.fm.)
#   2. `https://tickets.euphoric.gg/api/auth/callback/discord` registered on
#      the Discord application's OAuth2 → Redirects panel.
# ---------------------------------------------------------------------------
{$TICKETS_GG_HOSTNAME:tickets.euphoric.gg} {
  tls {
    key_type rsa2048
  }
  encode gzip zstd

  header {
    Strict-Transport-Security "max-age=31536000"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"
    # Iframe-safe for the in-game phone — match info.euphoric.fm.
    Content-Security-Policy "frame-ancestors *"
    -X-Frame-Options
    -Server
  }

  reverse_proxy tickets-web:3000 {
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    flush_interval -1
  }

  log {
    output stdout
    format json
    level INFO
  }
}
