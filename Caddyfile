# euphoricfm-website — Caddy serving a static Astro build.
#
# Listens on :${PORT:-6094} INSIDE the docker network. The host docker-compose
# binds 127.0.0.1:${PORT} only — cloudflared (host network mode) is the only
# public ingress and reaches us via that loopback.
#
# This site lives inside an in-game phone's iframe, so we explicitly allow
# embedding from anywhere via CSP frame-ancestors and DO NOT set X-Frame-Options.

{
  auto_https off
  admin off
}

:{$PORT:6094} {
  root * /srv/site
  encode gzip zstd

  # Iframeable from anywhere — this site is embedded inside an in-game phone.
  header Content-Security-Policy "frame-ancestors *"
  header -X-Frame-Options

  # /efm-runtime-config.js is served inline by Caddy with env-var substitution at
  # config-parse time — webhook URLs come from the container's env vars and
  # NEVER end up in the built static bundle. Edit `.env` + `docker compose up -d`
  # to swap a webhook; no rebuild needed.
  @runtimeConfig path /efm-runtime-config.js
  handle @runtimeConfig {
    header Content-Type "application/javascript; charset=utf-8"
    header Cache-Control "no-store"
    respond `(function(){window.__EFM_CONFIG__=window.__EFM_CONFIG__||{};window.__EFM_CONFIG__.discord={requestWebhook:"{$PUBLIC_DISCORD_REQUEST_WEBHOOK}",contactWebhook:"{$PUBLIC_DISCORD_CONTACT_WEBHOOK}"};})();`
  }

  file_server

  # Fingerprinted Astro assets — cache forever.
  @astroAssets path /_astro/*
  header @astroAssets Cache-Control "public, max-age=31536000, immutable"

  # Font files don't change once shipped — cache hard.
  @fonts path /fonts/*
  header @fonts Cache-Control "public, max-age=31536000, immutable"

  # Images cached for a week.
  @images path /images/*
  header @images Cache-Control "public, max-age=604800"

  # Icons and small meta files cached a day.
  @icons path /favicon.svg /favicon.ico /robots.txt /sitemap-index.xml /sitemap-*.xml
  header @icons Cache-Control "public, max-age=86400"

  handle_errors {
    @404 expression `{err.status_code} == 404`
    handle @404 {
      # Stop Cloudflare from caching 404s with its 4-hour default TTL.
      header Cache-Control "no-store, max-age=0"
      respond "Page not found — try the home page at /" 404
    }
  }
}
