---
import '../styles/global.css';
import { site } from '../site.config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.name,
  description = site.description,
  ogImage = '/images/og.jpg',
} = Astro.props;

const fullTitle = title === site.name ? title : `${title} — ${site.name}`;

// Client-side config — only fields used by nowplaying.ts.
const clientConfig = {
  apiBase: site.azuracast.apiBase,
  stationId: site.azuracast.stationId,
  pollMs: site.realtime.pollMs,
  mode: site.realtime.mode,
};
---

<!doctype html>
<html lang="en" class="bg-ink">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#293462" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="preconnect" href="https://euphoric.fm" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={Astro.url.toString()} />
  </head>
  <body class="overflow-x-hidden">
    <!-- Caddy renders /runtime-config.js from env vars at request time so
         webhook URLs aren't baked into the static bundle. Loaded first so the
         modals' inline scripts (later in body) can read window.__EFM_CONFIG__.discord. -->
    <script is:inline src="/efm-runtime-config.js"></script>
    <script is:inline define:vars={{ clientConfig }}>
      window.__EFM_CONFIG__ = Object.assign(window.__EFM_CONFIG__ || {}, clientConfig);
    </script>
    <main id="main"><slot /></main>

    <!-- Install banner — appears once on supporting browsers (Chrome/Edge/Brave)
         when the page is eligible for PWA install. Hidden by default. -->
    <div id="efm-install-banner" class="hidden efm-extras fixed inset-x-0 bottom-3 z-30 mx-auto max-w-md px-4">
      <div class="card !p-3 flex items-center gap-3 shadow-2xl">
        <img src="/icon.svg" alt="" class="w-10 h-10 rounded-lg" />
        <div class="min-w-0 flex-1">
          <div class="text-sm font-semibold text-cream">Install the EuphoricFM player</div>
          <div class="text-[11px] text-cream/60">Compact, resizable, lives in your dock or taskbar.</div>
        </div>
        <button id="efm-install-yes" type="button" class="btn !px-3 !py-2 btn-sunburst !min-h-0">Install</button>
        <button id="efm-install-no" type="button" class="text-cream/50 text-xl leading-none px-2" aria-label="Dismiss">&times;</button>
      </div>
    </div>

    <script>
      import '../scripts/nowplaying.ts';
    </script>
    <script is:inline>
      // Detect iframe context FIRST. The in-game phone (CEF-based) loads this
      // site inside an iframe — it is the most important use case. PWA bits
      // (service worker, install banner, pwa-mode class) are skipped there
      // because:
      //   - Service workers in iframes have unpredictable scope behaviour
      //     in older CEF builds and can cache broken state across sessions.
      //   - PWA install is meaningless inside an iframe.
      //   - display-mode media queries can misfire in CEF and mistakenly
      //     hide the .efm-extras content.
      let inIframe = false;
      try { inIframe = window.self !== window.top; } catch (_) { inIframe = true; }

      if (inIframe) {
        // Best-effort cleanup of any service worker registered by a previous
        // build, so visitors who already loaded the site don't stay stuck on
        // a cached version.
        if ('serviceWorker' in navigator && navigator.serviceWorker.getRegistrations) {
          navigator.serviceWorker.getRegistrations().then((regs) => {
            regs.forEach((r) => r.unregister().catch(() => {}));
          }).catch(() => {});
        }
      } else {
        // Standalone web view: register the service worker.
        if ('serviceWorker' in navigator) {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(() => {});
          });
        }

        // PWA install prompt + standalone detection — web only.
        (function () {
          let deferred = null;
          const banner = document.getElementById('efm-install-banner');
          const yes = document.getElementById('efm-install-yes');
          const no = document.getElementById('efm-install-no');
          const dismissedKey = 'efm-install-dismissed';

          const standalone = window.matchMedia('(display-mode: standalone)').matches ||
            window.matchMedia('(display-mode: minimal-ui)').matches ||
            window.matchMedia('(display-mode: window-controls-overlay)').matches ||
            window.navigator.standalone === true;
          if (standalone) document.body.classList.add('pwa-mode');

          if (banner && yes && no) {
            window.addEventListener('beforeinstallprompt', (e) => {
              e.preventDefault();
              deferred = e;
              if (localStorage.getItem(dismissedKey)) return;
              if (standalone) return;
              banner.classList.add('show');
            });
            yes.addEventListener('click', async () => {
              if (!deferred) return;
              banner.classList.remove('show');
              deferred.prompt();
              const choice = await deferred.userChoice.catch(() => null);
              deferred = null;
              if (choice && choice.outcome !== 'accepted') {
                localStorage.setItem(dismissedKey, '1');
              }
            });
            no.addEventListener('click', () => {
              banner.classList.remove('show');
              localStorage.setItem(dismissedKey, '1');
            });
            window.addEventListener('appinstalled', () => {
              banner.classList.remove('show');
              document.body.classList.add('pwa-mode');
            });
          }
        })();
      }
    </script>
  </body>
</html>
