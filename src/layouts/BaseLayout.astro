---
import '../styles/global.css';
import { site } from '../site.config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.name,
  description = site.description,
  ogImage = '/images/og.jpg',
} = Astro.props;

const fullTitle = title === site.name ? title : `${title} — ${site.name}`;

// Client-side config — only fields used by nowplaying.ts.
const clientConfig = {
  apiBase: site.azuracast.apiBase,
  stationId: site.azuracast.stationId,
  pollMs: site.realtime.pollMs,
  mode: site.realtime.mode,
};
---

<!doctype html>
<html lang="en" class="bg-ink">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- PWA bits (manifest, apple-touch-icon, theme-color, apple-mobile meta tags)
         were removed. The in-game phone is the primary use case, and some custom
         FiveM phone CEF builds were failing to first-paint the iframe when the
         document declared a manifest. Body still has system-ui fallback so the
         page looks identical without Inter loaded from Google Fonts. -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={Astro.url.toString()} />
  </head>
  <body class="overflow-x-hidden">
    <!-- Caddy renders /runtime-config.js from env vars at request time so
         webhook URLs aren't baked into the static bundle. Loaded first so the
         modals' inline scripts (later in body) can read window.__EFM_CONFIG__.discord. -->
    <script is:inline src="/efm-runtime-config.js"></script>
    <script is:inline define:vars={{ clientConfig }}>
      window.__EFM_CONFIG__ = Object.assign(window.__EFM_CONFIG__ || {}, clientConfig);
    </script>
    <main id="main"><slot /></main>

    <script>
      import '../scripts/nowplaying.ts';
    </script>
    <script is:inline>
      // Best-effort cleanup of any service worker registered by an earlier
      // build. sw.js itself is now a killswitch — visiting the page in any
      // context that supports SW fetches the new sw.js, which unregisters
      // itself and clears all caches on activate. The in-game phone is the
      // primary use case and SW lifecycle there is unpredictable.
      if ('serviceWorker' in navigator && navigator.serviceWorker.getRegistrations) {
        navigator.serviceWorker.getRegistrations().then((regs) => {
          regs.forEach((r) => r.unregister().catch(() => {}));
        }).catch(() => {});
      }
    </script>
  </body>
</html>
