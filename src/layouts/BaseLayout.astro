---
import '../styles/tokens.css';
import '../styles/global.css';
import { site } from '../site.config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.name,
  description = site.description,
  ogImage = '/images/og.jpg',
} = Astro.props;

const fullTitle = title === site.name ? title : `${title} — ${site.name}`;

// Client-side config — only fields used by nowplaying.ts.
const clientConfig = {
  apiBase: site.azuracast.apiBase,
  stationId: site.azuracast.stationId,
  pollMs: site.realtime.pollMs,
  mode: site.realtime.mode,
};
---

<!doctype html>
<html lang="en" class="bg-ink">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- PWA bits (manifest, apple-touch-icon, theme-color, apple-mobile meta tags)
         were removed. The in-game phone is the primary use case, and some custom
         FiveM phone CEF builds were failing to first-paint the iframe when the
         document declared a manifest. Body still has system-ui fallback so the
         page looks identical without Inter loaded from Google Fonts. -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={Astro.url.toString()} />
    <!-- Pre-paint environment setup, resolved BEFORE first paint so nothing
         flashes or blanks. Two independent decisions:

         1. FiveM in-game phone (CEF) safe mode. The phone embeds this site in an
            outdated CEF whose compositor can't render CSS blur/filter: a
            `filter` on <body> drops the whole frame (blank page) and
            `backdrop-filter` paints black rectangles (no gameview behind the
            iframe to sample). FiveM's NUI core stamps "CitizenFX" into the user
            agent (NUIInitialize.cpp), so detect that and add `html.efm-cef`,
            which the stylesheet uses to swap the heavy blur/filter layers for
            plain, CEF-safe equivalents. This is what blanked the phone after the
            0.7.3/0.8.0 effects landed.

         2. Effects on/off. Mirrors effects.ts's logic: explicit localStorage
            choice wins; otherwise default off under reduced-motion, on elsewhere.
            Sets `html.efm-fx-off` which CSS uses to force the static brand look. -->
    <script is:inline>
      (function () {
        var el = document.documentElement;
        try {
          if (/CitizenFX/i.test(navigator.userAgent)) el.classList.add('efm-cef');
        } catch (e) { /* navigator unavailable → assume a normal browser */ }
        try {
          var s = localStorage.getItem('efm-fx');
          var rm = window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches;
          var on = s ? s === 'on' : !rm;
          if (!on) el.classList.add('efm-fx-off');
        } catch (e) { /* storage blocked → default on */ }
      })();
    </script>
  </head>
  <body class="overflow-x-hidden">
    <!-- Fluid music-reactive backdrop. Three big blurred colour blobs that
         drift continuously (CSS keyframe orbits) so the background is alive at
         rest, and swell / shove / brighten to the beat via the --efm-* vars
         PlayerCard publishes on :root. Purely decorative: aria-hidden +
         pointer-events:none, pinned behind #main. See .efm-blob in global.css. -->
    <div class="efm-bg" aria-hidden="true">
      <div class="efm-orbit efm-orbit--blue"><div class="efm-float" style="--efm-depth: 0.6;"><div class="efm-blob efm-blob--blue"></div></div></div>
      <div class="efm-orbit efm-orbit--pink"><div class="efm-float" style="--efm-depth: 1;"><div class="efm-blob efm-blob--pink"></div></div></div>
      <div class="efm-orbit efm-orbit--gold"><div class="efm-float" style="--efm-depth: 0.8;"><div class="efm-blob efm-blob--gold"></div></div></div>
    </div>
    <!-- Caddy renders /runtime-config.js from env vars at request time so
         webhook URLs aren't baked into the static bundle. Loaded first so the
         modals' inline scripts (later in body) can read window.__EFM_CONFIG__.discord. -->
    <script is:inline src="/efm-runtime-config.js"></script>
    <script is:inline define:vars={{ clientConfig }}>
      window.__EFM_CONFIG__ = Object.assign(window.__EFM_CONFIG__ || {}, clientConfig);
    </script>
    <!-- relative + z-index keeps all content painting above the .efm-bg blobs. -->
    <main id="main" class="relative z-[1]"><slot /></main>

    <script>
      import '../scripts/nowplaying.ts';
      import '../scripts/effects.ts';
    </script>
    <script is:inline>
      // Best-effort cleanup of any service worker registered by an earlier
      // build. sw.js itself is now a killswitch — visiting the page in any
      // context that supports SW fetches the new sw.js, which unregisters
      // itself and clears all caches on activate. The in-game phone is the
      // primary use case and SW lifecycle there is unpredictable.
      if ('serviceWorker' in navigator && navigator.serviceWorker.getRegistrations) {
        navigator.serviceWorker.getRegistrations().then((regs) => {
          regs.forEach((r) => r.unregister().catch(() => {}));
        }).catch(() => {});
      }
    </script>
  </body>
</html>
