---
// Skeleton card — the client script `src/scripts/nowplaying.ts` hydrates the
// `#np-*` and `#recent-list` IDs on load and on every poll.
---

<section class="phone section pt-3">
  <div id="np-card" class="card !p-3 bg-midnight/40 border-midnight/40">
    <div class="flex items-start gap-3">
      <img
        id="np-art"
        src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'/%3E"
        alt=""
        class="w-20 h-20 rounded-lg object-cover bg-cream/10 shrink-0"
      />
      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2 mb-1">
          <span id="np-status" class="inline-block rounded-full px-2 py-0.5 text-[10px] font-bold tracking-widest bg-ruby/20 text-ruby">LIVE</span>
          <span class="text-[10px] uppercase tracking-widest text-cream/40">Now Playing</span>
        </div>
        <div id="np-title" class="truncate text-base font-bold text-cream">Loading…</div>
        <div id="np-artist" class="truncate text-sm text-cream/75">—</div>
        <div id="np-album" class="truncate text-xs text-cream/45 mt-0.5"></div>
      </div>
    </div>

    <div class="mt-3">
      <div class="h-1.5 w-full rounded-full bg-cream/10 overflow-hidden">
        <div id="np-bar" class="h-full bg-gradient-to-r from-sunburst to-lemon transition-[width] duration-300" style="width: 0%"></div>
      </div>
      <div class="mt-1.5 flex items-center justify-between text-[10px] text-cream/55">
        <span id="np-times">0:00 / 0:00</span>
        <span><span id="np-listeners">0</span> listening</span>
      </div>
    </div>
  </div>
</section>
