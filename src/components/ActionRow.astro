---
// Four-button action row: Request, Submit, Contact, Business AD.
// Click handlers dispatch CustomEvents that the modal components listen for.
---

<section class="phone section pt-2">
  <div class="grid grid-cols-2 gap-2">
    <button type="button" id="open-request" class="btn btn-sunburst">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M9 18V6l12-2v12"/><circle cx="7" cy="18" r="2"/><circle cx="19" cy="16" r="2"/></svg>
      Request a song
    </button>
    <button type="button" id="open-submit" class="btn btn-midnight">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M12 5v14M5 12h14"/></svg>
      Submit a song
    </button>
    <button type="button" id="open-contact" class="btn btn-ruby">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M4 12a8 8 0 0 1 16 0"/><path d="M4 12v6a2 2 0 0 0 2 2h1v-8H6a2 2 0 0 0-2 2"/><path d="M20 12v6a2 2 0 0 1-2 2h-1v-8h1a2 2 0 0 1 2 2"/></svg>
      Contact us
    </button>
    <button type="button" id="open-business" class="btn btn-mixed">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M3 11v2"/><path d="M7 10v4"/><path d="M11 8v8"/><path d="M11 8l9-3v14l-9-3"/></svg>
      Business AD
    </button>
  </div>
</section>

<script is:inline>
  (function () {
    const fire = (name) => document.dispatchEvent(new CustomEvent(name));
    document.getElementById('open-request')?.addEventListener('click', () => fire('efm:open-request'));
    document.getElementById('open-submit')?.addEventListener('click', () => fire('efm:open-submit'));
    document.getElementById('open-contact')?.addEventListener('click', () => fire('efm:open-contact'));
    document.getElementById('open-business')?.addEventListener('click', () => fire('efm:open-business'));

    // Shared close: any element with data-close="<overlay-id>" closes that overlay.
    document.addEventListener('click', (e) => {
      const el = e.target.closest('[data-close]');
      if (!el) return;
      const id = el.getAttribute('data-close');
      const overlay = id ? document.getElementById(id) : null;
      if (overlay) { overlay.classList.add('hidden'); overlay.setAttribute('aria-hidden', 'true'); }
    });

    // Escape key closes any open overlay.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      ['request-overlay', 'submit-overlay', 'contact-overlay', 'business-overlay'].forEach((id) => {
        const o = document.getElementById(id);
        if (o && !o.classList.contains('hidden')) {
          o.classList.add('hidden');
          o.setAttribute('aria-hidden', 'true');
        }
      });
    });
  })();
</script>
