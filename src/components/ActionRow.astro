---
// Four-button action row: Request, Submit, Contact, Business AD.
// Click handlers dispatch CustomEvents that the modal components listen for.
// Uses View Transitions API for smooth modal open if supported.
---

<section class="pt-2">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 lg:gap-3">
    <button type="button" id="open-request" class="btn btn-sunburst">Request a song</button>
    <button type="button" id="open-submit" class="btn btn-midnight">Submit a song</button>
    <button type="button" id="open-contact" class="btn btn-ruby">Contact us</button>
    <button type="button" id="open-business" class="btn btn-mixed">Business AD</button>
  </div>
</section>

<script is:inline>
  (function () {
    // View Transitions API wrapper — falls back to a plain dispatch on browsers
    // that don't support it. Either way the event fires; the API just adds a
    // smooth crossfade on supporting browsers.
    const fire = (name) => {
      const dispatch = () => document.dispatchEvent(new CustomEvent(name));
      if (typeof document.startViewTransition === 'function') {
        document.startViewTransition(dispatch);
      } else {
        dispatch();
      }
    };

    document.getElementById('open-request')?.addEventListener('click', () => fire('efm:open-request'));
    document.getElementById('open-submit')?.addEventListener('click', () => fire('efm:open-submit'));
    document.getElementById('open-contact')?.addEventListener('click', () => fire('efm:open-contact'));
    document.getElementById('open-business')?.addEventListener('click', () => fire('efm:open-business'));

    // Shared close: any element with data-close="<overlay-id>" closes that overlay.
    document.addEventListener('click', (e) => {
      const el = e.target.closest('[data-close]');
      if (!el) return;
      const id = el.getAttribute('data-close');
      const overlay = id ? document.getElementById(id) : null;
      if (!overlay) return;
      const doClose = () => { overlay.classList.add('hidden'); overlay.setAttribute('aria-hidden', 'true'); };
      if (typeof document.startViewTransition === 'function') {
        document.startViewTransition(doClose);
      } else {
        doClose();
      }
    });

    // Escape key closes any open overlay.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      ['request-overlay', 'submit-overlay', 'contact-overlay', 'business-overlay'].forEach((id) => {
        const o = document.getElementById(id);
        if (o && !o.classList.contains('hidden')) {
          o.classList.add('hidden');
          o.setAttribute('aria-hidden', 'true');
        }
      });
    });
  })();
</script>
