---
import { site } from '../site.config';
---

<section class="phone section pt-2">
  <div class="card !p-3 flex items-center gap-3">
    <button
      id="efm-play"
      type="button"
      class="shrink-0 inline-flex items-center justify-center w-12 h-12 rounded-full bg-sunburst text-ink shadow-lg active:scale-95 transition-transform"
      aria-label="Play"
    >
      <svg id="efm-play-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M8 5v14l11-7z"/></svg>
    </button>
    <div class="min-w-0 flex-1">
      <div class="text-xs uppercase tracking-widest text-cream/55">Stream</div>
      <div class="text-sm font-semibold text-cream truncate">Tap play to tune in</div>
    </div>
    <input
      id="efm-volume"
      type="range"
      min="0"
      max="100"
      value="80"
      aria-label="Volume"
      class="w-20 accent-sunburst"
    />
    <audio id="efm-audio" preload="none" crossorigin="anonymous"></audio>
  </div>
</section>

<script is:inline define:vars={{ streamUrl: site.azuracast.streamUrl }}>
  (function () {
    const audio = document.getElementById('efm-audio');
    const btn = document.getElementById('efm-play');
    const icon = document.getElementById('efm-play-icon');
    const vol = document.getElementById('efm-volume');
    if (!audio || !btn || !icon || !vol) return;

    const playIcon = '<path d="M8 5v14l11-7z"/>';
    const pauseIcon = '<path d="M6 5h4v14H6zM14 5h4v14h-4z"/>';

    audio.volume = Number(vol.value) / 100;

    btn.addEventListener('click', async () => {
      try {
        if (audio.paused) {
          // Always set src on play to force a fresh stream (in-game phones can
          // freeze the audio element when the iframe is hidden).
          audio.src = streamUrl + (streamUrl.includes('?') ? '&' : '?') + 't=' + Date.now();
          await audio.play();
          icon.innerHTML = pauseIcon;
        } else {
          audio.pause();
          audio.removeAttribute('src');
          audio.load();
          icon.innerHTML = playIcon;
        }
      } catch (err) {
        console.warn('[efm] audio play failed', err);
      }
    });

    vol.addEventListener('input', () => {
      audio.volume = Number(vol.value) / 100;
    });

    audio.addEventListener('ended', () => { icon.innerHTML = playIcon; });
    audio.addEventListener('error', () => { icon.innerHTML = playIcon; });
  })();
</script>
