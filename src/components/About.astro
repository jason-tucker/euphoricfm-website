---
import { site } from '../site.config';
const paragraphs = site.aboutText.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
---

<section class="phone section">
  <div class="card">
    <h2 class="text-base font-bold tracking-wide text-sunburst">What is EuphoricFM?</h2>
    {paragraphs.map((p) => <p class="mt-3 text-sm leading-relaxed text-cream/85">{p}</p>)}
  </div>
</section>
