---
import { site } from '../site.config';
---

<header class="pt-4 pb-2 text-center lg:pt-5 lg:pb-3">
  <h1 class="leading-none">
    <span class="font-euphoric text-sunburst text-5xl md:text-5xl lg:text-5xl align-middle">Euphoric</span><span
      class="font-fm text-ruby text-5xl md:text-5xl lg:text-5xl align-middle ml-1">FM</span>
  </h1>
  <p class="mt-1 text-[11px] uppercase tracking-[0.25em] text-cream/55">{site.tagline}</p>
</header>
