---
import { site } from '../site.config';
---

<header class="pt-5 pb-3 text-center lg:pt-8 lg:pb-5">
  <h1 class="leading-none">
    <span class="font-euphoric text-sunburst text-5xl md:text-6xl lg:text-7xl align-middle">Euphoric</span><span
      class="font-fm text-ruby text-5xl md:text-6xl lg:text-7xl align-middle ml-1">FM</span>
  </h1>
  <p class="mt-1 text-[11px] md:text-xs uppercase tracking-[0.25em] text-cream/55">{site.tagline}</p>
</header>
