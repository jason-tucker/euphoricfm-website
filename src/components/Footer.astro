---
import { VERSION, SHORT_SHA } from '../lib/version';
const year = new Date().getFullYear();
const releaseUrl = `https://github.com/jason-tucker/euphoricfm-website/releases/tag/v${VERSION}`;
---

<footer class="phone py-6 mt-4 text-center text-[10px] text-cream/45">
  <div>&copy; {year} EuphoricFM</div>
  <div class="mt-1">
    <a href={releaseUrl} target="_blank" rel="noopener" class="hover:text-cream/70 underline-offset-2 hover:underline">
      v{VERSION} · {SHORT_SHA}
    </a>
  </div>
</footer>
