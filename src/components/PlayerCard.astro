---
import { site } from '../site.config';
---

<!-- Unified player: now-playing + transport controls + visualizer + up-next.
     The script in this file owns the audio element + Web Audio analyser.
     `src/scripts/nowplaying.ts` hydrates the #np-* hooks on every poll. -->
<section class="pt-2">
  <div id="np-card" class="card vt-np !p-3 lg:!p-4 bg-midnight/40 border-midnight/40 overflow-hidden relative">

    <!-- Top row: artwork + track info. Stays side-by-side at every breakpoint
         so the card doesn't blow up vertically on desktop. -->
    <div class="flex items-start gap-3 lg:gap-5">
      <div class="relative shrink-0">
        <img
          id="np-art"
          src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'/%3E"
          alt=""
          class="vt-art w-20 h-20 lg:w-40 lg:h-40 rounded-lg lg:rounded-xl object-cover bg-cream/10 shadow-xl"
        />
        <div class="hidden lg:block absolute inset-0 rounded-xl pointer-events-none ring-1 ring-inset ring-cream/10"></div>
      </div>

      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2 mb-1">
          <span id="np-status" class="inline-block rounded-full px-2 py-0.5 text-[10px] font-bold tracking-widest bg-ruby/20 text-ruby">LIVE</span>
          <span class="text-[10px] uppercase tracking-widest text-cream/40">Now Playing</span>
        </div>
        <div id="np-title" class="truncate text-base lg:text-xl font-bold text-cream">Loading…</div>
        <div id="np-artist" class="truncate text-sm lg:text-base text-cream/75">—</div>
        <div id="np-album" class="truncate text-xs lg:text-sm text-cream/45 mt-0.5"></div>
      </div>
    </div>

    <!-- Progress bar + times -->
    <div class="mt-3 lg:mt-4">
      <div class="h-1.5 lg:h-2 w-full rounded-full bg-cream/10 overflow-hidden">
        <div id="np-bar" class="h-full bg-gradient-to-r from-sunburst to-lemon transition-[width] duration-300 shadow-[0_0_20px_rgba(254,177,57,0.45)]" style="width: 0%"></div>
      </div>
      <div class="mt-1.5 flex items-center justify-between text-[10px] lg:text-xs text-cream/60">
        <span id="np-times">0:00 / 0:00</span>
        <span><span id="np-listeners">0</span> listening</span>
      </div>
    </div>

    <!-- Transport row: play + volume -->
    <div class="mt-3 lg:mt-3 flex items-center gap-3">
      <button
        id="efm-play"
        type="button"
        class="shrink-0 inline-flex items-center justify-center w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-sunburst text-ink shadow-lg active:scale-95 transition-transform"
        aria-label="Play"
      >
        <svg id="efm-play-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 lg:w-7 lg:h-7"><path d="M8 5v14l11-7z"/></svg>
      </button>
      <div class="min-w-0 flex-1">
        <div class="text-[10px] uppercase tracking-widest text-cream/50">Stream</div>
        <div id="efm-play-label" class="text-sm lg:text-base font-semibold text-cream truncate">Tap play to tune in</div>
      </div>
      <input
        id="efm-volume"
        type="range"
        min="0"
        max="100"
        value="80"
        aria-label="Volume"
        class="w-20 lg:w-28 accent-sunburst"
      />
      <audio id="efm-audio" preload="none" crossorigin="anonymous"></audio>
    </div>

    <!-- Up Next — slides down from the bottom of the card when playing_next is present. -->
    <div id="np-up-next" class="mt-3 overflow-hidden max-h-0 opacity-0 transition-[max-height,opacity] duration-500 ease-out">
      <div class="border-t border-cream/10 pt-3 flex items-center gap-3">
        <div class="text-[10px] uppercase tracking-widest text-cream/45 shrink-0">Up Next</div>
        <img id="up-next-art" src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'/%3E" alt="" class="w-9 h-9 rounded-md object-cover bg-cream/10 shrink-0" />
        <div class="min-w-0 flex-1">
          <div id="up-next-title" class="truncate text-xs lg:text-sm font-semibold text-cream">—</div>
          <div id="up-next-artist" class="truncate text-[10px] lg:text-xs text-cream/60">—</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Up-next reveal — driven by .is-open class on #np-up-next. */
  #np-up-next.is-open {
    max-height: 80px;
    opacity: 1;
  }
</style>

<script is:inline define:vars={{ streamUrl: site.azuracast.streamUrl }}>
  (function () {
    const audio = document.getElementById('efm-audio');
    const btn = document.getElementById('efm-play');
    const icon = document.getElementById('efm-play-icon');
    const vol = document.getElementById('efm-volume');
    const label = document.getElementById('efm-play-label');
    const card = document.getElementById('np-card');
    if (!audio || !btn || !icon || !vol) return;

    const playIcon = '<path d="M8 5v14l11-7z"/>';
    const pauseIcon = '<path d="M6 5h4v14H6zM14 5h4v14h-4z"/>';
    audio.volume = Number(vol.value) / 100;

    let audioCtx = null;
    let analyser = null;
    let dataArr = null;
    let rafId = 0;
    let sourceNode = null;

    const setupAnalyser = async () => {
      try {
        if (audioCtx) {
          if (audioCtx.state === 'suspended') await audioCtx.resume();
          return true;
        }
        const AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return false;
        audioCtx = new AC();
        if (audioCtx.state === 'suspended') await audioCtx.resume();

        sourceNode = audioCtx.createMediaElementSource(audio);
        analyser = audioCtx.createAnalyser();
        // The bass-glow loop only needs the bottom of the spectrum, so a
        // smaller FFT is fine and cheaper. Smoothing kept low so kicks hit.
        analyser.fftSize = 256;
        analyser.smoothingTimeConstant = 0.55;
        analyser.minDecibels = -85;
        analyser.maxDecibels = -10;
        dataArr = new Uint8Array(analyser.frequencyBinCount);
        sourceNode.connect(analyser);
        analyser.connect(audioCtx.destination);
        return true;
      } catch (err) {
        console.warn('[efm] Web Audio unavailable; bass glow disabled', err);
        return false;
      }
    };

    // Bass-glow tick — reads only the lowest ~6% of frequency bins each
    // frame, averages them, and writes the value to `--efm-bass` on the
    // player card. CSS in global.css drives the box-shadow halo from that.
    const tickGlow = () => {
      if (analyser && dataArr) {
        analyser.getByteFrequencyData(dataArr);
        const bassCount = Math.max(4, Math.floor(dataArr.length * 0.06));
        let sum = 0;
        for (let i = 0; i < bassCount; i++) sum += dataArr[i];
        const bass = (sum / bassCount) / 255;
        if (card) card.style.setProperty('--efm-bass', bass.toFixed(3));
      }
      rafId = requestAnimationFrame(tickGlow);
    };

    const startGlow = async () => {
      const ok = await setupAnalyser();
      if (!ok) return;
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(tickGlow);
    };
    const stopGlow = () => {
      cancelAnimationFrame(rafId);
      if (card) card.style.removeProperty('--efm-bass');
    };

    // Belt-and-suspenders crossOrigin — guarantees the Origin header is sent
    // so AnalyserNode gets real PCM data for the bass-glow loop.
    audio.crossOrigin = 'anonymous';

    btn.addEventListener('click', async () => {
      try {
        if (audio.paused) {
          audio.src = streamUrl + (streamUrl.includes('?') ? '&' : '?') + 't=' + Date.now();
          await audio.play();
          icon.innerHTML = pauseIcon;
          if (label) label.textContent = 'Streaming live';
          await startGlow();
        } else {
          audio.pause();
          audio.removeAttribute('src');
          audio.load();
          icon.innerHTML = playIcon;
          if (label) label.textContent = 'Tap play to tune in';
          stopGlow();
        }
      } catch (err) {
        console.warn('[efm] audio play failed', err);
      }
    });

    vol.addEventListener('input', () => { audio.volume = Number(vol.value) / 100; });
    audio.addEventListener('ended', () => { icon.innerHTML = playIcon; stopGlow(); });
    audio.addEventListener('error', () => { icon.innerHTML = playIcon; stopGlow(); });

    // Bridge for Media Session API in nowplaying.ts.
    window.__efmAudio = {
      play: () => btn.click(),
      pause: () => { if (!audio.paused) btn.click(); },
      el: audio,
    };
  })();
</script>
