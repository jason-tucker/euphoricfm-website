---
import { site } from '../site.config';
---

<!-- Unified player: now-playing + transport controls + visualizer + up-next.
     The inline script owns the audio element + Web Audio analyser, and
     writes --efm-bass / --efm-mid / --efm-high / --efm-energy CSS variables
     on :root every frame so anything on the page can react to the music. -->
<section class="pt-2">
  <!-- No overflow-hidden here: the bass halo lives on #np-card::before and its
       box-shadow paints OUTSIDE the card box — an ancestor clip would erase it.
       Children that need clipping (#np-up-next, the progress track) clip themselves. -->
  <div id="np-card" class="card vt-np bg-midnight/40 border-midnight/40 relative">

    <!-- Top row: artwork + track info + transport stack. Layout:
           [art] [LIVE/Now Playing/title/artist/album] [PLAY button stacked over VOL slider]
         The separate "Stream / Streaming live" transport row beneath the
         progress bar is gone — the LIVE pill above already signals state. -->
    <div class="flex items-start" style="gap: clamp(0.75rem, 1.5vw, 1.25rem);">
      <div class="relative shrink-0">
        <img
          id="np-art"
          src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'/%3E"
          alt=""
          class="vt-art rounded-lg object-cover bg-cream/10 shadow-xl block"
          style="width: clamp(5rem, 14vw, 10rem); height: clamp(5rem, 14vw, 10rem);"
        />
        <div class="absolute inset-0 rounded-lg pointer-events-none ring-1 ring-inset ring-cream/10"></div>
      </div>

      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2 mb-1 flex-wrap">
          <span id="np-status" class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[10px] font-bold tracking-widest bg-ruby/20 text-ruby">
            <span id="np-live-dot" class="inline-block w-1.5 h-1.5 rounded-full bg-ruby"></span>LIVE
          </span>
          <span class="text-[10px] uppercase tracking-widest text-cream/40">Now Playing</span>
          <!-- Shown by nowplaying.ts when now_playing.is_request === true. -->
          <span id="np-requested" class="hidden rounded-full px-2 py-0.5 text-[10px] font-bold tracking-widest bg-sunburst/25 text-sunburst">REQUESTED</span>
        </div>
        <div id="np-title" class="truncate font-bold text-cream" style="font-size: clamp(1rem, 1.8vw, 1.375rem);">Loading…</div>
        <div id="np-artist" class="truncate text-cream/75" style="font-size: clamp(0.875rem, 1.3vw, 1.0625rem);">—</div>
        <div id="np-album" class="truncate text-cream/45 mt-0.5" style="font-size: clamp(0.75rem, 1.1vw, 0.9375rem);"></div>
      </div>

      <!-- Transport stack — play button over volume slider, top-right of the
           card. Width clamps so the title block isn't squeezed on a 360px
           in-game phone iframe. -->
      <div class="shrink-0 flex flex-col items-end" style="gap: clamp(0.5rem, 0.8vw, 0.625rem); width: clamp(3rem, 8vw, 5rem);">
        <button
          id="efm-play"
          type="button"
          class="inline-flex items-center justify-center rounded-full bg-sunburst text-ink shadow-lg active:scale-95 transition-transform"
          style="width: clamp(3rem, 4.5vw, 3.75rem); height: clamp(3rem, 4.5vw, 3.75rem);"
          aria-label="Play"
        >
          <svg id="efm-play-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="ml-0.5" style="width: clamp(1.5rem, 2vw, 1.875rem); height: clamp(1.5rem, 2vw, 1.875rem);"><path d="M8 5v14l11-7z"/></svg>
        </button>
        <input
          id="efm-volume"
          type="range"
          min="0"
          max="100"
          value="80"
          aria-label="Volume"
          class="efm-range w-full"
        />
        <audio id="efm-audio" preload="none" crossorigin="anonymous"></audio>
      </div>
    </div>

    <!-- Progress bar + times. Bar shimmers with mid frequencies when playing. -->
    <div style="margin-top: clamp(0.75rem, 1.2vw, 1rem);">
      <div id="np-bar-track" class="w-full rounded-full bg-cream/10 overflow-hidden relative" style="height: clamp(0.375rem, 0.5vw, 0.5rem);">
        <div id="np-bar" class="h-full bg-gradient-to-r from-sunburst to-gold transition-[width] duration-300" style="width: 0%"></div>
      </div>
      <div class="mt-1.5 flex items-center justify-between text-cream/60" style="font-size: clamp(0.625rem, 0.85vw, 0.75rem);">
        <span id="np-times">0:00 / 0:00</span>
        <span><span id="np-listeners">0</span> listening</span>
      </div>
    </div>

    <!-- Up Next — slides down from the bottom of the card when playing_next is present. -->
    <div id="np-up-next" class="mt-3 overflow-hidden max-h-0 opacity-0 transition-[max-height,opacity] duration-500 ease-out">
      <div class="border-t border-cream/10 pt-3 flex items-center gap-3">
        <div class="text-[10px] uppercase tracking-widest text-cream/45 shrink-0">Up Next</div>
        <img id="up-next-art" src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'/%3E" alt="" class="w-9 h-9 rounded-md object-cover bg-cream/10 shrink-0" />
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2">
            <div id="up-next-title" class="truncate text-xs lg:text-sm font-semibold text-cream">—</div>
            <!-- Shown by nowplaying.ts when playing_next.is_request === true. -->
            <span id="up-next-requested" class="hidden shrink-0 rounded-full px-1.5 py-px text-[9px] font-bold tracking-widest bg-sunburst/25 text-sunburst">REQUESTED</span>
          </div>
          <div id="up-next-artist" class="truncate text-[10px] lg:text-xs text-cream/60">—</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Up-next reveal — driven by .is-open class on #np-up-next. */
  #np-up-next.is-open {
    max-height: 80px;
    opacity: 1;
  }

  /* Custom range slider — integrated, slim. Cross-browser styling. */
  input.efm-range {
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    border-radius: 9999px;
    background: linear-gradient(
      to right,
      rgb(var(--efm-sunburst-rgb)) 0%,
      rgb(var(--efm-sunburst-rgb)) var(--vol, 80%),
      rgb(var(--efm-cream-rgb) / 0.12) var(--vol, 80%),
      rgb(var(--efm-cream-rgb) / 0.12) 100%
    );
    cursor: pointer;
  }
  input.efm-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background: rgb(var(--efm-sunburst-rgb));
    box-shadow: 0 0 0 2px rgb(var(--efm-ink-rgb) / 0.6);
    cursor: pointer;
  }
  input.efm-range::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background: rgb(var(--efm-sunburst-rgb));
    border: 2px solid rgb(var(--efm-ink-rgb) / 0.6);
    cursor: pointer;
  }
</style>

<script is:inline define:vars={{ streamUrl: site.azuracast.streamUrl }}>
  (function () {
    const audio = document.getElementById('efm-audio');
    const btn = document.getElementById('efm-play');
    const icon = document.getElementById('efm-play-icon');
    const vol = document.getElementById('efm-volume');
    const card = document.getElementById('np-card');
    if (!audio || !btn || !icon || !vol) return;

    const root = document.documentElement;

    const playIcon = '<path d="M8 5v14l11-7z"/>';
    const pauseIcon = '<path d="M6 5h4v14H6zM14 5h4v14h-4z"/>';
    audio.volume = Number(vol.value) / 100;
    vol.style.setProperty('--vol', vol.value + '%');

    let audioCtx = null;
    let analyser = null;
    let dataArr = null;
    let rafId = 0;
    let sourceNode = null;
    let playing = false;

    const setupAnalyser = async () => {
      try {
        if (audioCtx) {
          if (audioCtx.state === 'suspended') await audioCtx.resume();
          return true;
        }
        const AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return false;
        audioCtx = new AC();
        if (audioCtx.state === 'suspended') await audioCtx.resume();

        sourceNode = audioCtx.createMediaElementSource(audio);
        analyser = audioCtx.createAnalyser();
        // 256 bins gives us enough resolution for bass/mid/high splits while
        // keeping the per-frame copy cheap.
        analyser.fftSize = 256;
        analyser.smoothingTimeConstant = 0.55;
        analyser.minDecibels = -85;
        analyser.maxDecibels = -10;
        dataArr = new Uint8Array(analyser.frequencyBinCount);
        sourceNode.connect(analyser);
        analyser.connect(audioCtx.destination);
        return true;
      } catch (err) {
        console.warn('[efm] Web Audio unavailable; reactions disabled', err);
        return false;
      }
    };

    // Per-frame tick — reads the FFT and writes four CSS variables on :root
    // so anything on the page can react. Bands split roughly:
    //   bass:  0 –  8% of bins  (kick + bass)
    //   mid:   8 – 35%          (vocals, snare, instruments)
    //   high: 35 – 100%         (cymbals, brightness)
    //   energy: average of all  (overall loudness)
    const tickReact = () => {
      if (analyser && dataArr) {
        analyser.getByteFrequencyData(dataArr);
        const n = dataArr.length;
        const bassEnd = Math.max(2, Math.floor(n * 0.08));
        const midEnd  = Math.max(bassEnd + 2, Math.floor(n * 0.35));
        let bs = 0, md = 0, hi = 0, all = 0;
        for (let i = 0; i < n; i++) {
          const v = dataArr[i];
          all += v;
          if (i < bassEnd) bs += v;
          else if (i < midEnd) md += v;
          else hi += v;
        }
        const bass = (bs / bassEnd) / 255;
        const mid  = (md / (midEnd - bassEnd)) / 255;
        const high = (hi / (n - midEnd)) / 255;
        const energy = (all / n) / 255;
        root.style.setProperty('--efm-bass',   bass.toFixed(3));
        root.style.setProperty('--efm-mid',    mid.toFixed(3));
        root.style.setProperty('--efm-high',   high.toFixed(3));
        root.style.setProperty('--efm-energy', energy.toFixed(3));
      }
      rafId = requestAnimationFrame(tickReact);
    };

    const startReact = async () => {
      // Effects toggle (effects.ts) can disable all visual reactivity while the
      // music keeps playing. window.__efmFx is the live flag.
      if (window.__efmFx && !window.__efmFx.on) return;
      const ok = await setupAnalyser();
      if (!ok) return;
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(tickReact);
    };
    const stopReact = () => {
      cancelAnimationFrame(rafId);
      // Reset all reactivity vars so the page settles back to its idle look.
      root.style.removeProperty('--efm-bass');
      root.style.removeProperty('--efm-mid');
      root.style.removeProperty('--efm-high');
      root.style.removeProperty('--efm-energy');
      if (card) card.classList.remove('is-playing');
    };

    audio.crossOrigin = 'anonymous';

    const setPlayingUI = (isPlaying) => {
      playing = isPlaying;
      icon.innerHTML = isPlaying ? pauseIcon : playIcon;
      btn.setAttribute('aria-label', isPlaying ? 'Pause' : 'Play');
      if (card) card.classList.toggle('is-playing', isPlaying);
    };

    btn.addEventListener('click', async () => {
      try {
        if (audio.paused) {
          audio.src = streamUrl + (streamUrl.includes('?') ? '&' : '?') + 't=' + Date.now();
          await audio.play();
          setPlayingUI(true);
          await startReact();
        } else {
          audio.pause();
          audio.removeAttribute('src');
          audio.load();
          setPlayingUI(false);
          stopReact();
        }
      } catch (err) {
        console.warn('[efm] audio play failed', err);
      }
    });

    vol.addEventListener('input', () => {
      audio.volume = Number(vol.value) / 100;
      vol.style.setProperty('--vol', vol.value + '%');
    });
    audio.addEventListener('ended', () => { setPlayingUI(false); stopReact(); });
    audio.addEventListener('error', () => { setPlayingUI(false); stopReact(); });

    // Effects toggle flipped (effects.ts): stop writing FFT vars when off, and
    // resume if it's turned back on mid-playback. Music itself is unaffected.
    document.addEventListener('efm:fx-change', (e) => {
      const on = e.detail && e.detail.on;
      if (!on) stopReact();
      else if (playing) startReact();
    });

    // Bridge for Media Session API in nowplaying.ts.
    window.__efmAudio = {
      play: () => btn.click(),
      pause: () => { if (!audio.paused) btn.click(); },
      el: audio,
    };
  })();
</script>
