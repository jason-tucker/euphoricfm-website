---
import { site } from '../site.config';
---

<div
  id="request-overlay"
  class="hidden fixed inset-0 z-40 bg-ink/80 backdrop-blur-sm"
  aria-hidden="true"
>
  <div class="mx-auto max-w-md w-full h-full flex flex-col py-4 px-4 lg:py-10">
    <div class="card efm-modal-enter !p-4 flex-1 flex flex-col overflow-hidden lg:max-h-[80vh]">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-base font-bold text-sunburst">Request a Song</h2>
        <button
          type="button"
          class="text-cream/60 text-xl leading-none px-2"
          data-close="request-overlay"
          aria-label="Close"
        >&times;</button>
      </div>
      <p class="text-xs text-cream/60 mb-3">Search the EuphoricFM library and tap a song to request it.</p>

      <input
        id="req-search"
        type="text"
        class="input mb-3"
        placeholder="Search title or artist…"
        autocomplete="off"
      />

      <ul id="req-results" class="flex-1 overflow-y-auto divide-y divide-cream/5 -mx-1 px-1">
        <li class="py-2 text-xs text-cream/40">Type to search the library.</li>
      </ul>

      <div id="req-toast" class="hidden mt-3 text-xs px-3 py-2 rounded-lg"></div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ apiBase: site.azuracast.apiBase, stationId: site.azuracast.stationId }}>
  (function () {
    const overlay = document.getElementById('request-overlay');
    const input = document.getElementById('req-search');
    const list = document.getElementById('req-results');
    const toast = document.getElementById('req-toast');
    if (!overlay || !input || !list || !toast) return;

    const escapeHtml = (s) =>
      String(s).replace(/[&<>"']/g, (c) =>
        c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '"' ? '&quot;' : '&#39;');

    let timer = null;
    const search = async (q) => {
      try {
        const url = new URL(`${apiBase}/station/${stationId}/requests`);
        if (q) url.searchParams.set('searchPhrase', q);
        const r = await fetch(url.toString(), { cache: 'no-store' });
        if (!r.ok) { list.innerHTML = '<li class="py-2 text-xs text-ruby">Failed to load library.</li>'; return; }
        const data = await r.json();
        const items = Array.isArray(data) ? data : (data.rows || []);
        if (!items.length) {
          list.innerHTML = '<li class="py-2 text-xs text-cream/40">No matches.</li>';
          return;
        }
        list.innerHTML = items.slice(0, 30).map((it) => {
          const s = it.song || {};
          const title = escapeHtml(s.title || s.text || 'Unknown');
          const artist = escapeHtml(s.artist || '');
          const art = s.art || '';
          // Song id + metadata ride along as data-* so the click handler can
          // hand the full record to submitRequest() — needed to track the
          // pending request in localStorage and prune it once we see the
          // same song.id in now_playing or song_history.
          return `<li>
            <button type="button"
              data-request-url="${escapeHtml(it.request_url || '')}"
              data-song-id="${escapeHtml(s.id || '')}"
              data-song-title="${title}"
              data-song-artist="${artist}"
              data-song-art="${escapeHtml(art)}"
              class="w-full text-left flex items-center gap-3 py-2 hover:bg-cream/5 rounded-md px-1 transition-colors">
              <img src="${art}" alt="" class="w-10 h-10 rounded-md object-cover bg-cream/10 shrink-0" loading="lazy">
              <div class="min-w-0 flex-1">
                <div class="truncate text-sm font-semibold text-cream">${title}</div>
                <div class="truncate text-xs text-cream/60">${artist}</div>
              </div>
              <span class="text-[10px] uppercase tracking-wider text-sunburst shrink-0">Request</span>
            </button>
          </li>`;
        }).join('');
      } catch (err) {
        console.warn('[efm] search failed', err);
        list.innerHTML = '<li class="py-2 text-xs text-ruby">Failed to load library.</li>';
      }
    };

    const showToast = (msg, kind) => {
      toast.textContent = msg;
      toast.className = 'mt-3 text-xs px-3 py-2 rounded-lg ' +
        (kind === 'error' ? 'bg-ruby/15 text-ruby border border-ruby/30' : 'bg-sunburst/15 text-sunburst border border-sunburst/30');
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 4000);
    };

    const PENDING_KEY = 'efm:pendingRequests';
    const PENDING_TTL_MS = 6 * 60 * 60 * 1000; // 6h safety: drop stragglers
    const PENDING_MAX = 10;

    const readPending = () => {
      try {
        const raw = localStorage.getItem(PENDING_KEY);
        if (!raw) return [];
        const arr = JSON.parse(raw);
        return Array.isArray(arr) ? arr : [];
      } catch { return []; }
    };
    const writePending = (arr) => {
      try { localStorage.setItem(PENDING_KEY, JSON.stringify(arr)); } catch {}
      // Notify the sidebar renderer (nowplaying.ts) to re-paint immediately
      // — otherwise the new entry doesn't appear until the next 5s poll.
      document.dispatchEvent(new CustomEvent('efm:pending-changed'));
    };
    const pushPending = (song) => {
      if (!song || !song.id) return;
      const now = Date.now();
      const existing = readPending().filter(
        (p) => p && p.id !== song.id && now - (p.ts || 0) < PENDING_TTL_MS,
      );
      existing.push({
        id: song.id,
        title: song.title,
        artist: song.artist,
        art: song.art,
        ts: now,
      });
      // Bound the list so localStorage can't grow unbounded if AzuraCast
      // rejects requests silently for a long stretch.
      while (existing.length > PENDING_MAX) existing.shift();
      writePending(existing);
    };

    const submitRequest = async (requestUrl, song) => {
      try {
        // POST same-origin through the Caddy /api/* proxy. AzuraCast doesn't
        // set Access-Control-Allow-Origin on the actual POST reply, so a
        // direct cross-origin POST submits server-side but the browser
        // blocks JS from reading the response and the fetch rejects.
        let path = requestUrl;
        if (/^https?:\/\//.test(path)) {
          try { path = new URL(path).pathname; } catch {}
        }
        const r = await fetch(path, { method: 'POST', cache: 'no-store' });
        const text = await r.text();
        let body = null; try { body = JSON.parse(text); } catch {}
        if (r.ok && body && body.success !== false) {
          showToast('Request submitted! It will play soon.', 'ok');
          pushPending(song);
        } else {
          const msg = (body && (body.formatted_message || body.message)) || `Couldn't submit request (HTTP ${r.status}).`;
          showToast(msg, 'error');
        }
      } catch (err) {
        console.warn('[efm] request failed', err);
        showToast('Network error submitting request.', 'error');
      }
    };

    input.addEventListener('input', () => {
      const q = input.value.trim();
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => search(q), 250);
    });

    list.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-request-url]');
      if (!btn) return;
      const url = btn.getAttribute('data-request-url');
      const song = {
        id: btn.getAttribute('data-song-id') || '',
        title: btn.getAttribute('data-song-title') || '',
        artist: btn.getAttribute('data-song-artist') || '',
        art: btn.getAttribute('data-song-art') || '',
      };
      if (url) submitRequest(url, song);
    });

    // Open hook — load initial library when opened.
    document.addEventListener('efm:open-request', () => {
      overlay.classList.remove('hidden');
      overlay.setAttribute('aria-hidden', 'false');
      if (!list.dataset.loaded) {
        list.dataset.loaded = '1';
        search('');
      }
      input.focus();
    });
  })();
</script>
