---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import PlayerCard from '../components/PlayerCard.astro';
import ActionRow from '../components/ActionRow.astro';
import RecentlyPlayed from '../components/RecentlyPlayed.astro';
import RequestedSongs from '../components/RequestedSongs.astro';
import About from '../components/About.astro';
import RequestModal from '../components/RequestModal.astro';
import SubmitSongModal from '../components/SubmitSongModal.astro';
import ContactModal from '../components/ContactModal.astro';
import BusinessAdModal from '../components/BusinessAdModal.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <div class="phone">
    <Header />

    <!-- Fully fluid hero. .efm-hero in global.css collapses to one column
         on narrow viewports (in-game phone) and grows to player + sidebar
         the moment there's enough room — no breakpoint jump, gap and padding
         interpolate via clamp(). -->
    <div class="efm-hero">
      <div>
        <PlayerCard />
        <div class="efm-extras">
          <ActionRow />
        </div>
      </div>
      <aside class="efm-extras efm-sidebar">
        <RecentlyPlayed />
        <RequestedSongs />
      </aside>
    </div>

    <div class="efm-extras">
      <About />
    </div>
    <Footer />
  </div>

  <RequestModal />
  <SubmitSongModal />
  <ContactModal />
  <BusinessAdModal />
</BaseLayout>
