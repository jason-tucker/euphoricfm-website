# euphoricfm-website — environment template
#
# Copy to .env and adjust. .env is gitignored.

# Image pulled by watchtower from GHCR. CI publishes :latest on every merge to main.
IMAGE=ghcr.io/jason-tucker/euphoricfm-website:latest

# Loopback port Caddy binds to on the host. Cloudflared (standalone on the
# host) reaches us at 127.0.0.1:${PORT}. NEVER expose to 0.0.0.0.
PORT=6094

# Public URL — used for canonical/og:url. Override per environment.
PUBLIC_BASE_URL=https://info.euphoric.fm

# Discord webhook URLs — the modals POST to these. Easy to swap without rebuilding
# the image because they're read at runtime by a `<script>` tag in BaseLayout
# via window.__EFM_CONFIG__ which is populated from these env vars at build time.
PUBLIC_DISCORD_REQUEST_WEBHOOK=https://discord.com/api/webhooks/1416845833013559337/14NVcSFhQ1kWu3AOUhfcIxEwlzacEcNjfNhWfQVNs6kab81qWf-0vmr-6xUtEEASpRtW
PUBLIC_DISCORD_CONTACT_WEBHOOK=https://discord.com/api/webhooks/1460091711043797046/FDiqu1V5sqJu2XWakdslO7TPJDES4O6TpXefUMlcFF0tT5ch4NXXS1K5pwN-aMLQ4hiQ
