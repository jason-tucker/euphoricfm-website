# euphoricfm-website — environment template
#
# Copy to .env and adjust. .env is gitignored.

# Image pulled by watchtower from GHCR. CI publishes :latest on every merge to main.
IMAGE=ghcr.io/jason-tucker/euphoricfm-website:latest

# Loopback port Caddy binds to on the host. Cloudflared (standalone on the
# host) reaches us at 127.0.0.1:${PORT}. NEVER expose to 0.0.0.0.
PORT=6094

# Public URL — used for canonical/og:url. Override per environment.
PUBLIC_BASE_URL=https://info.euphoric.fm

# Discord webhook URLs — the SubmitSongModal and ContactModal POST to these.
# These are required for the forms to work. Get the URLs from the Discord
# channel integration settings. NEVER commit real webhook URLs to this file.
PUBLIC_DISCORD_REQUEST_WEBHOOK=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME
PUBLIC_DISCORD_CONTACT_WEBHOOK=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME
